{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumaForge Profiles Release Index",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "version",
    "generatedAt",
    "release",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "release": {
      "type": "object",
      "required": [
        "provider",
        "owner",
        "repo",
        "tag"
      ],
      "properties": {
        "provider": {
          "const": "github"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schemaVersion",
          "id",
          "kind",
          "version",
          "title",
          "license",
          "redistributionAllowed",
          "manifest",
          "assets"
        ],
        "properties": {
          "schemaVersion": {
            "const": 1
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "lut",
              "look-profile",
              "camera-profile",
              "lens-correction-profile",
              "color-transform-profile"
            ]
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "redistributionAllowed": {
            "const": true
          },
          "manifest": {
            "type": "object",
            "required": [
              "originalPath",
              "releaseAssetName"
            ],
            "properties": {
              "originalPath": {
                "type": "string",
                "minLength": 1
              },
              "releaseAssetName": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._-]+$"
              }
            },
            "additionalProperties": false
          },
          "assets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "role",
                "mediaType",
                "originalPath",
                "releaseAssetName",
                "size",
                "sha256",
                "download"
              ],
              "properties": {
                "role": {
                  "type": "string",
                  "minLength": 1
                },
                "mediaType": {
                  "type": "string",
                  "minLength": 1
                },
                "originalPath": {
                  "type": "string",
                  "minLength": 1
                },
                "releaseAssetName": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9._-]+$"
                },
                "size": {
                  "type": "integer",
                  "minimum": 1
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-fA-F0-9]{64}$"
                },
                "download": {
                  "type": "object",
                  "required": [
                    "type",
                    "url"
                  ],
                  "properties": {
                    "type": {
                      "const": "github-release-asset"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
