{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumaForge Profiles Repository Index",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "entriesRoot",
    "defaultEntryGlob",
    "generatedAt",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entriesRoot": {
      "type": "string",
      "minLength": 1
    },
    "defaultEntryGlob": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "format",
          "version",
          "title",
          "manifest"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "manifest": {
            "type": "string",
            "minLength": 1
          },
          "lut": {
            "$ref": "#/$defs/lutMetadata"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "rgbTriple": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "lutMetadata": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "enum": [
            "1d",
            "3d"
          ]
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "domainMin": {
          "$ref": "#/$defs/rgbTriple"
        },
        "domainMax": {
          "$ref": "#/$defs/rgbTriple"
        },
        "vendor": {
          "type": "string",
          "minLength": 1
        },
        "inputTransfer": {
          "type": "string",
          "minLength": 1
        },
        "inputGamut": {
          "type": "string",
          "minLength": 1
        },
        "outputTransfer": {
          "type": "string",
          "minLength": 1
        },
        "outputGamut": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "enum": [
            "look",
            "technical-output",
            "display-look",
            "scene-creative",
            "combined-look-output",
            "monitoring",
            "calibration",
            "unknown"
          ]
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "variant": {
          "type": "string",
          "minLength": 1
        },
        "contractSource": {
          "type": "string",
          "minLength": 1
        },
        "contractSourceId": {
          "type": "string",
          "minLength": 1
        },
        "contractConfidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  }
}
