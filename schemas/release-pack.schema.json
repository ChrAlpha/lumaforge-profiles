{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumaForge Profiles Release Pack Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "tag",
    "kindFilter",
    "entryCount",
    "assetCount",
    "uncompressedBytes",
    "generatedAt",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "minLength": 1
    },
    "kindFilter": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entryCount": {
      "type": "integer",
      "minimum": 0
    },
    "assetCount": {
      "type": "integer",
      "minimum": 0
    },
    "uncompressedBytes": {
      "type": "integer",
      "minimum": 0
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "manifest"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "manifest": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
