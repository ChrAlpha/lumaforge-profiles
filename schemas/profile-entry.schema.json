{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumaForge Profile Entry Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "format",
    "version",
    "title",
    "description",
    "license",
    "author",
    "source",
    "sourceUrl",
    "redistributionAllowed",
    "targets",
    "assets",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "lut",
        "look-profile",
        "camera-profile",
        "lens-correction-profile",
        "color-transform-profile"
      ]
    },
    "format": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "license": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "sourceUrl": {
      "type": [
        "string",
        "null"
      ]
    },
    "redistributionAllowed": {
      "type": "boolean"
    },
    "targets": {
      "type": "object"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "path",
          "mediaType",
          "byteSize",
          "sha256"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "cube-lut",
              "camera-profile",
              "dcp",
              "icc",
              "lens-correction",
              "lcp",
              "metadata",
              "license",
              "notice"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "byteSize": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    },
    "lut": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
