{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumaForge Profile Entry Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "format",
    "version",
    "title",
    "description",
    "license",
    "author",
    "source",
    "sourceUrl",
    "redistributionAllowed",
    "targets",
    "assets",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "lut",
        "look-profile",
        "camera-profile",
        "lens-correction-profile",
        "color-transform-profile"
      ]
    },
    "format": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "license": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "sourceUrl": {
      "type": ["string", "null"]
    },
    "redistributionAllowed": {
      "type": "boolean"
    },
    "targets": {
      "type": "object"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "path", "mediaType", "byteSize", "sha256"],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "cube-lut",
              "camera-profile",
              "dcp",
              "icc",
              "lens-correction",
              "lcp",
              "look-profile",
              "color-transform",
              "metadata",
              "license",
              "notice"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "byteSize": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string",
      "minLength": 1
    },
    "lut": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "dimension": {
          "type": "string",
          "enum": ["1d", "3d"]
        },
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "domainMin": {
          "$ref": "#/$defs/rgbTriple"
        },
        "domainMax": {
          "$ref": "#/$defs/rgbTriple"
        },
        "vendor": {
          "type": "string",
          "minLength": 1
        },
        "inputTransfer": {
          "type": "string",
          "minLength": 1
        },
        "inputGamut": {
          "type": "string",
          "minLength": 1
        },
        "outputTransfer": {
          "type": "string",
          "minLength": 1
        },
        "outputGamut": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "enum": [
            "look",
            "technical-output",
            "display-look",
            "scene-creative",
            "combined-look-output",
            "monitoring",
            "calibration",
            "unknown"
          ]
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "variant": {
          "type": "string",
          "minLength": 1
        },
        "contractSource": {
          "type": "string",
          "minLength": 1
        },
        "contractSourceId": {
          "type": "string",
          "minLength": 1
        },
        "contractConfidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "rgbTriple": {
      "type": "array",
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    }
  }
}
