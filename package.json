{
  "name": "@lumaforge/profiles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "profiles": "tsx src/cli.ts",
    "profiles:import": "tsx src/cli.ts import",
    "profiles:validate": "tsx src/cli.ts validate",
    "profiles:index": "tsx src/cli.ts index",
    "profiles:build-r2": "tsx src/cli.ts build-r2",
    "profiles:publish-r2:dry-run": "tsx src/cli.ts publish-r2 --dry-run",
    "profiles:publish-r2": "tsx src/cli.ts publish-r2 --yes",
    "profiles:r2:gc": "tsx src/cli.ts r2-gc",
    "profiles:build-release": "tsx src/cli.ts build-release",
    "profiles:pack": "tsx src/cli.ts pack",
    "profiles:release:dry-run": "tsx src/cli.ts release --dry-run",
    "profiles:release": "tsx src/cli.ts release --yes",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
