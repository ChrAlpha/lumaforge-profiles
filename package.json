{
  "name": "@lumaforge/profiles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "profiles": "tsx src/cli.ts",
    "profiles:import": "tsx src/cli.ts import",
    "profiles:refresh-assets": "tsx src/cli.ts refresh-assets",
    "profiles:validate": "tsx src/cli.ts validate",
    "profiles:index": "tsx src/cli.ts index",
    "profiles:build-s3": "tsx src/cli.ts build-s3",
    "profiles:publish-s3:dry-run": "tsx src/cli.ts publish-s3 --dry-run",
    "profiles:publish-s3": "tsx src/cli.ts publish-s3 --yes",
    "profiles:s3:gc": "tsx src/cli.ts s3-gc",
    "profiles:build-release": "tsx src/cli.ts build-release",
    "profiles:pack": "tsx src/cli.ts pack",
    "profiles:release:dry-run": "tsx src/cli.ts release --dry-run",
    "profiles:release": "tsx src/cli.ts release --yes",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:web": "vitest run src/web/__tests__",
    "test:layout": "vitest run test/test-layout.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "commander": "^13.1.0",
    "dotenv": "^17.4.2",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
